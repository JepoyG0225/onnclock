[Unit]
Description=OnClock Biometric Kiosk
After=graphical-session.target network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/pi/.Xauthority
WorkingDirectory=/opt/onclock-kiosk
ExecStart=/usr/bin/python3 /opt/onclock-kiosk/onclock_kiosk.py
Restart=always
RestartSec=5

[Install]
WantedBy=graphical-session.target
