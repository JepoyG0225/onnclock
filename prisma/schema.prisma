generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  HR_MANAGER
  PAYROLL_OFFICER
  EMPLOYEE
}

enum EmploymentStatus {
  PROBATIONARY
  REGULAR
  CONTRACTUAL
  PROJECT_BASED
  PART_TIME
  RESIGNED
  TERMINATED
  RETIRED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACTUAL
}

enum PayFrequency {
  SEMI_MONTHLY
  MONTHLY
  WEEKLY
  DAILY
}

enum RateType {
  MONTHLY
  DAILY
  HOURLY
}

enum PayrollRunStatus {
  DRAFT
  COMPUTED
  FOR_APPROVAL
  APPROVED
  LOCKED
  CANCELLED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LoanType {
  SSS_SALARY_LOAN
  SSS_CALAMITY_LOAN
  PAGIBIG_MULTI_PURPOSE
  PAGIBIG_CALAMITY
  COMPANY_LOAN
  OTHER
}

enum LoanStatus {
  ACTIVE
  FULLY_PAID
  CANCELLED
}

enum SubscriptionPlan {
  TRIAL
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  UNPAID
  PAID
  VOID
}

enum PaymentMethodType {
  GCASH
  BANK_TRANSFER
  E_WALLET
  OTHER
}

enum HolidayType {
  REGULAR
  SPECIAL_NON_WORKING
  SPECIAL_WORKING
}

enum WorkScheduleType {
  FIXED
  FLEXITIME
  SHIFTING
  COMPRESSED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum CivilStatus {
  SINGLE
  MARRIED
  WIDOWED
  LEGALLY_SEPARATED
}

// ─────────────────────────────────────────────
// AUTH USERS
// ─────────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String
  name                String?
  isActive            Boolean   @default(true)
  lastLoginAt         DateTime?
  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  companies       UserCompany[]
  approverConfigs ApproverConfig[]

  @@map("users")
}

// ─────────────────────────────────────────────
// MULTI-TENANCY: COMPANIES
// ─────────────────────────────────────────────

model Company {
  id                String   @id @default(cuid())
  name              String
  tradeName         String?
  industry          String?
  tin               String?
  sssRegistrationNo String?
  philhealthNo      String?
  pagibigNo         String?
  address           String?
  city              String?
  province          String?
  zipCode           String?
  phone             String?
  email             String?
  website           String?
  birNo             String?
  portalUrl         String?
  portalSubdomain   String?  @unique
  logoUrl           String?  @db.Text
  geofenceEnabled   Boolean  @default(false)
  fingerprintRequired Boolean @default(true)
  geofenceLat       Float?
  geofenceLng       Float?
  geofenceRadiusMeters Int?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users               UserCompany[]
  departments         Department[]
  positions           Position[]
  payGrades           PayGrade[]
  employees           Employee[]
  workSchedules       WorkSchedule[]
  holidays            Holiday[]
  payrollRuns         PayrollRun[]
  leaveTypes          LeaveType[]
  loans               EmployeeLoan[]
  contributionConfig  ContributionConfig?
  deMinimisConfig     DeMinimisConfig?
  thirteenthMonthLogs ThirteenthMonthLog[]
  rolePermissions     CompanyRolePermission[]
  approverConfigs     ApproverConfig[]
  subscription        Subscription?
  invoices            Invoice[]

  @@map("companies")
}

// ─────────────────────────────────────────────
// USER MANAGEMENT
// ─────────────────────────────────────────────

model UserCompany {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      UserRole @default(EMPLOYEE)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
  @@map("user_companies")
}

// ─────────────────────────────────────────────
// ORGANIZATIONAL STRUCTURE
// ─────────────────────────────────────────────

model Department {
  id        String   @id @default(cuid())
  companyId String
  name      String
  code      String?
  parentId  String?
  headId    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company      @relation(fields: [companyId], references: [id])
  parent    Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DeptHierarchy")
  employees Employee[]

  @@map("departments")
}

model Position {
  id         String   @id @default(cuid())
  companyId  String
  title      String
  code       String?
  payGradeId String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id])
  payGrade  PayGrade? @relation(fields: [payGradeId], references: [id])
  employees Employee[]

  @@map("positions")
}

model PayGrade {
  id        String   @id @default(cuid())
  companyId String
  name      String
  minSalary Decimal  @db.Decimal(12, 2)
  maxSalary Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company    @relation(fields: [companyId], references: [id])
  positions Position[]

  @@map("pay_grades")
}

// ─────────────────────────────────────────────
// EMPLOYEE 201 FILE
// ─────────────────────────────────────────────

model Employee {
  id                 String           @id @default(cuid())
  companyId          String
  employeeNo         String
  userId             String?

  lastName           String
  firstName          String
  middleName         String?
  suffix             String?
  gender             Gender
  birthDate          DateTime         @db.Date
  birthPlace         String?
  civilStatus        CivilStatus      @default(SINGLE)
  nationality        String           @default("Filipino")
  religion           String?

  personalEmail      String?
  workEmail          String?
  mobileNo           String?
  phoneNo            String?

  presentAddress     String?
  permanentAddress   String?

  sssNo              String?
  tinNo              String?
  philhealthNo       String?
  pagibigNo          String?

  emergencyContactName     String?
  emergencyContactRelation String?
  emergencyContactPhone    String?

  departmentId       String?
  positionId         String?
  directManagerId    String?
  employmentStatus   EmploymentStatus @default(PROBATIONARY)
  employmentType     EmploymentType   @default(FULL_TIME)
  hireDate           DateTime         @db.Date
  regularizationDate DateTime?        @db.Date
  resignationDate    DateTime?        @db.Date
  terminationDate    DateTime?        @db.Date

  rateType           RateType         @default(MONTHLY)
  basicSalary        Decimal          @db.Decimal(12, 2)
  dailyRate          Decimal?         @db.Decimal(10, 2)
  hourlyRate         Decimal?         @db.Decimal(8, 2)
  payFrequency       PayFrequency     @default(SEMI_MONTHLY)
  workScheduleId     String?

  bankName      String?
  bankAccountNo String?

  isExemptFromTax     Boolean @default(false)
  isMinimumWageEarner Boolean @default(false)
  trackTime           Boolean @default(false)
  isActive            Boolean @default(true)

  photoUrl  String?
  faceEmbedding Json?
  faceEmbeddingModel String?
  faceSetupAt DateTime?
  faceConsentAt DateTime?
  faceSetupPhoto String? @db.Text
  biometricCredential   Json?
  biometricChallenge    String?
  biometricChallengeAt  DateTime?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id])
  department   Department?   @relation(fields: [departmentId], references: [id])
  position     Position?     @relation(fields: [positionId], references: [id])
  workSchedule WorkSchedule? @relation(fields: [workScheduleId], references: [id])
  manager      Employee?     @relation("ManagerSubordinate", fields: [directManagerId], references: [id])
  subordinates Employee[]    @relation("ManagerSubordinate")

  documents       EmployeeDocument[]
  leaveBalances   LeaveBalance[]
  leaveRequests   LeaveRequest[]
  dtrRecords      DTRRecord[]
  payslips        Payslip[]
  loans           EmployeeLoan[]
  taxExemptions   TaxExemption[]
  deMinimisItems  DeMinimisItem[]
  overtimeRecords     OvertimeRecord[]
  locationPings       LocationPing[]
  thirteenthMonthLogs ThirteenthMonthLog[]

  @@unique([companyId, employeeNo])
  @@map("employees")
}


model EmployeeDocument {
  id           String    @id @default(cuid())
  employeeId   String
  documentType String
  fileName     String
  fileUrl      String
  uploadedAt   DateTime  @default(now())
  expiresAt    DateTime?
  notes        String?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_documents")
}

// ─────────────────────────────────────────────
// WORK SCHEDULE & HOLIDAYS
// ─────────────────────────────────────────────

model WorkSchedule {
  id              String           @id @default(cuid())
  companyId       String
  name            String
  scheduleType    WorkScheduleType @default(FIXED)
  requireSelfieOnClockIn Boolean   @default(false)
  workDays        Json
  timeIn          String?
  timeOut         String?
  breakMinutes    Int              @default(60)
  workHoursPerDay Decimal          @db.Decimal(4, 2) @default(8)
  workDaysPerWeek Int              @default(5)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  company        Company         @relation(fields: [companyId], references: [id])
  employees      Employee[]
  scheduleShifts ScheduleShift[]

  @@map("work_schedules")
}

model ScheduleShift {
  id             String       @id @default(cuid())
  workScheduleId String
  shiftName      String
  dayOfWeek      Int?
  timeIn         String
  timeOut        String
  breakMinutes   Int          @default(60)

  workSchedule WorkSchedule @relation(fields: [workScheduleId], references: [id])

  @@map("schedule_shifts")
}

model Holiday {
  id          String      @id @default(cuid())
  companyId   String
  name        String
  date        DateTime    @db.Date
  type        HolidayType
  isRecurring Boolean     @default(true)
  description String?
  createdAt   DateTime    @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@map("holidays")
}

// ─────────────────────────────────────────────
// DAILY TIME RECORD (DTR)
// ─────────────────────────────────────────────

model DTRRecord {
  id               String       @id @default(cuid())
  employeeId       String
  date             DateTime     @db.Date
  timeIn           DateTime?
  timeOut          DateTime?
  breakIn          DateTime?
  breakOut         DateTime?
  regularHours     Decimal?     @db.Decimal(6, 2)
  overtimeHours    Decimal?     @db.Decimal(6, 2)
  nightDiffHours   Decimal?     @db.Decimal(6, 2)
  lateMinutes      Int?         @default(0)
  undertimeMinutes Int?         @default(0)
  isRestDay        Boolean      @default(false)
  isHoliday        Boolean      @default(false)
  holidayType      HolidayType?
  isAbsent         Boolean      @default(false)
  isLeave          Boolean      @default(false)
  isLeavePaid      Boolean      @default(false)
  leaveRequestId   String?
  source           String       @default("MANUAL")
  remarks          String?
  approvedBy       String?

  // GPS / Geolocation
  clockInLat       Float?
  clockInLng       Float?
  clockInAccuracy  Float?
  clockInAddress   String?
  clockInPhoto     String?  @db.Text
  clockOutLat      Float?
  clockOutLng      Float?
  clockOutAccuracy Float?
  clockOutAddress  String?

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  employee         Employee         @relation(fields: [employeeId], references: [id])
  locationPings    LocationPing[]

  @@unique([employeeId, date])
  @@map("dtr_records")
}

// ─────────────────────────────────────────────
// LEAVE MANAGEMENT
// ─────────────────────────────────────────────

model LeaveType {
  id                String   @id @default(cuid())
  companyId         String
  name              String
  code              String
  daysEntitled      Decimal  @db.Decimal(6, 2)
  isWithPay         Boolean  @default(true)
  isPaidOut         Boolean  @default(false)
  isMandatory       Boolean  @default(true)
  requiresDocuments Boolean  @default(false)
  genderRestriction String?
  accrualType       String   @default("ANNUAL")
  carryOver         Boolean  @default(false)
  maxCarryOver      Decimal? @db.Decimal(6, 2)
  isActive          Boolean  @default(true)
  description       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company       Company        @relation(fields: [companyId], references: [id])
  leaveBalances LeaveBalance[]
  leaveRequests LeaveRequest[]

  @@unique([companyId, code])
  @@map("leave_types")
}

model LeaveBalance {
  id          String   @id @default(cuid())
  employeeId  String
  leaveTypeId String
  year        Int
  entitled    Decimal  @db.Decimal(6, 2)
  used        Decimal  @db.Decimal(6, 2) @default(0)
  pending     Decimal  @db.Decimal(6, 2) @default(0)
  carriedOver Decimal  @db.Decimal(6, 2) @default(0)
  encashed    Decimal  @db.Decimal(6, 2) @default(0)
  updatedAt   DateTime @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
  @@map("leave_balances")
}

model LeaveRequest {
  id             String      @id @default(cuid())
  employeeId     String
  leaveTypeId    String
  startDate      DateTime    @db.Date
  endDate        DateTime    @db.Date
  totalDays      Decimal     @db.Decimal(6, 2)
  reason         String?
  status         LeaveStatus @default(PENDING)
  approvalLevel  Int         @default(0)
  approvalTrail  Json        @default("[]")
  supportingDocs Json     @default("[]")
  reviewedBy     String?
  reviewedAt     DateTime?
  reviewNotes    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@map("leave_requests")
}

// ─────────────────────────────────────────────
// CONTRIBUTION CONFIGURATION
// ─────────────────────────────────────────────

model ContributionConfig {
  id                   String   @id @default(cuid())
  companyId            String   @unique
  sssEmployeeRate      Decimal  @db.Decimal(6, 4) @default(0.0450)
  sssEmployerRate      Decimal  @db.Decimal(6, 4) @default(0.0950)
  sssEcRate            Decimal  @db.Decimal(6, 4) @default(0.0010)
  sssMinMsc            Decimal  @db.Decimal(12, 2) @default(4000)
  sssMaxMsc            Decimal  @db.Decimal(12, 2) @default(30000)
  philhealthRate       Decimal  @db.Decimal(6, 4) @default(0.0500)
  philhealthMinPremium Decimal  @db.Decimal(12, 2) @default(500)
  philhealthMaxSalary  Decimal  @db.Decimal(12, 2) @default(100000)
  pagibigEmployeeRate1 Decimal  @db.Decimal(6, 4) @default(0.0100)
  pagibigEmployeeRate2 Decimal  @db.Decimal(6, 4) @default(0.0200)
  pagibigThreshold     Decimal  @db.Decimal(12, 2) @default(1500)
  pagibigEmployerRate  Decimal  @db.Decimal(6, 4) @default(0.0200)
  pagibigMaxEmployee   Decimal  @db.Decimal(12, 2) @default(100)
  pagibigMaxEmployer   Decimal  @db.Decimal(12, 2) @default(100)
  updatedAt            DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@map("contribution_configs")
}

// ─────────────────────────────────────────────
// PAYROLL RUN
// ─────────────────────────────────────────────

model PayrollRun {
  id              String           @id @default(cuid())
  companyId       String
  periodLabel     String
  periodStart     DateTime         @db.Date
  periodEnd       DateTime         @db.Date
  payFrequency    PayFrequency
  payDate         DateTime         @db.Date
  status          PayrollRunStatus @default(DRAFT)
  approvalLevel   Int              @default(0)
  approvalTrail   Json             @default("[]")
  totalBasic      Decimal          @db.Decimal(14, 2) @default(0)
  totalGross      Decimal          @db.Decimal(14, 2) @default(0)
  totalDeductions Decimal          @db.Decimal(14, 2) @default(0)
  totalNetPay     Decimal          @db.Decimal(14, 2) @default(0)
  totalSssEr      Decimal          @db.Decimal(14, 2) @default(0)
  totalPhEr       Decimal          @db.Decimal(14, 2) @default(0)
  totalPagibigEr  Decimal          @db.Decimal(14, 2) @default(0)
  createdBy       String
  approvedBy      String?
  approvedAt      DateTime?
  lockedAt        DateTime?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  company  Company   @relation(fields: [companyId], references: [id])
  payslips Payslip[]

  @@map("payroll_runs")
}

model Payslip {
  id                          String   @id @default(cuid())
  payrollRunId                String
  employeeId                  String
  basicSalary                 Decimal  @db.Decimal(12, 2)
  dailyRate                   Decimal  @db.Decimal(10, 2)
  daysWorked                  Decimal  @db.Decimal(6, 2)
  hoursWorked                 Decimal  @db.Decimal(8, 2) @default(0)
  regularOtHours              Decimal  @db.Decimal(6, 2) @default(0)
  regularOtAmount             Decimal  @db.Decimal(12, 2) @default(0)
  restDayOtHours              Decimal  @db.Decimal(6, 2) @default(0)
  restDayOtAmount             Decimal  @db.Decimal(12, 2) @default(0)
  holidayOtHours              Decimal  @db.Decimal(6, 2) @default(0)
  holidayOtAmount             Decimal  @db.Decimal(12, 2) @default(0)
  nightDiffHours              Decimal  @db.Decimal(6, 2) @default(0)
  nightDiffAmount             Decimal  @db.Decimal(12, 2) @default(0)
  holidayPayAmount            Decimal  @db.Decimal(12, 2) @default(0)
  riceAllowance               Decimal  @db.Decimal(12, 2) @default(0)
  clothingAllowance           Decimal  @db.Decimal(12, 2) @default(0)
  medicalAllowance            Decimal  @db.Decimal(12, 2) @default(0)
  otherAllowances             Decimal  @db.Decimal(12, 2) @default(0)
  otherEarnings               Decimal  @db.Decimal(12, 2) @default(0)
  grossPay                    Decimal  @db.Decimal(12, 2)
  sssEmployee                 Decimal  @db.Decimal(10, 2) @default(0)
  sssEc                       Decimal  @db.Decimal(10, 2) @default(0)
  philhealthEmployee          Decimal  @db.Decimal(10, 2) @default(0)
  pagibigEmployee             Decimal  @db.Decimal(10, 2) @default(0)
  withholdingTax              Decimal  @db.Decimal(10, 2) @default(0)
  sssEmployer                 Decimal  @db.Decimal(10, 2) @default(0)
  philhealthEmployer          Decimal  @db.Decimal(10, 2) @default(0)
  pagibigEmployer             Decimal  @db.Decimal(10, 2) @default(0)
  sssLoanDeduction            Decimal  @db.Decimal(10, 2) @default(0)
  pagibigLoan                 Decimal  @db.Decimal(10, 2) @default(0)
  companyLoan                 Decimal  @db.Decimal(10, 2) @default(0)
  lateDeduction               Decimal  @db.Decimal(10, 2) @default(0)
  undertimeDeduction          Decimal  @db.Decimal(10, 2) @default(0)
  absenceDeduction            Decimal  @db.Decimal(10, 2) @default(0)
  otherDeductions             Decimal  @db.Decimal(10, 2) @default(0)
  totalDeductions             Decimal  @db.Decimal(12, 2)
  netPay                      Decimal  @db.Decimal(12, 2)
  thirteenthMonthContribution Decimal  @db.Decimal(12, 2) @default(0)
  taxableIncome               Decimal  @db.Decimal(12, 2) @default(0)
  nonTaxableIncome            Decimal  @db.Decimal(12, 2) @default(0)
  ytdGrossPay                 Decimal  @db.Decimal(14, 2) @default(0)
  ytdTaxableIncome            Decimal  @db.Decimal(14, 2) @default(0)
  ytdWithholdingTax           Decimal  @db.Decimal(14, 2) @default(0)
  pdfUrl                      String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  payrollRun     PayrollRun           @relation(fields: [payrollRunId], references: [id])
  employee       Employee             @relation(fields: [employeeId], references: [id])
  loanDeductions PayslipLoanDeduction[]

  @@unique([payrollRunId, employeeId])
  @@map("payslips")
}

model OvertimeRecord {
  id           String   @id @default(cuid())
  employeeId   String
  date         DateTime @db.Date
  hours        Decimal  @db.Decimal(6, 2)
  type         String
  rate         Decimal  @db.Decimal(6, 4)
  amount       Decimal  @db.Decimal(12, 2)
  approvedBy   String?
  payrollRunId String?
  remarks      String?
  createdAt    DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("overtime_records")
}

// ─────────────────────────────────────────────
// LOANS
// ─────────────────────────────────────────────

model EmployeeLoan {
  id                  String     @id @default(cuid())
  companyId           String
  employeeId          String
  loanType            LoanType
  loanNo              String?
  principalAmount     Decimal    @db.Decimal(12, 2)
  balance             Decimal    @db.Decimal(12, 2)
  monthlyAmortization Decimal    @db.Decimal(10, 2)
  startDate           DateTime   @db.Date
  endDate             DateTime?  @db.Date
  status              LoanStatus @default(ACTIVE)
  notes               String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  company    Company              @relation(fields: [companyId], references: [id])
  employee   Employee             @relation(fields: [employeeId], references: [id])
  deductions PayslipLoanDeduction[]

  @@map("employee_loans")
}

model PayslipLoanDeduction {
  id        String   @id @default(cuid())
  payslipId String
  loanId    String
  amount    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  payslip Payslip      @relation(fields: [payslipId], references: [id])
  loan    EmployeeLoan @relation(fields: [loanId], references: [id])

  @@map("payslip_loan_deductions")
}

// ─────────────────────────────────────────────
// DE MINIMIS BENEFITS
// ─────────────────────────────────────────────

model DeMinimisConfig {
  id                String   @id @default(cuid())
  companyId         String   @unique
  riceSubsidy       Decimal  @db.Decimal(10, 2) @default(2000)
  clothingAllowance Decimal  @db.Decimal(10, 2) @default(6000)
  medicalCash       Decimal  @db.Decimal(10, 2) @default(10000)
  laundryAllowance  Decimal  @db.Decimal(10, 2) @default(300)
  mealAllowance     Decimal  @db.Decimal(10, 2) @default(2000)
  updatedAt         DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@map("de_minimis_configs")
}

model DeMinimisItem {
  id          String   @id @default(cuid())
  employeeId  String
  period      String
  riceSubsidy Decimal  @db.Decimal(10, 2) @default(0)
  clothing    Decimal  @db.Decimal(10, 2) @default(0)
  medical     Decimal  @db.Decimal(10, 2) @default(0)
  laundry     Decimal  @db.Decimal(10, 2) @default(0)
  meal        Decimal  @db.Decimal(10, 2) @default(0)
  other       Decimal  @db.Decimal(10, 2) @default(0)
  total       Decimal  @db.Decimal(10, 2) @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, period])
  @@map("de_minimis_items")
}

// ─────────────────────────────────────────────
// TAX EXEMPTIONS
// ─────────────────────────────────────────────

model TaxExemption {
  id                       String   @id @default(cuid())
  employeeId               String
  effectiveYear            Int
  status                   String   @default("S")
  qualifyingDependents     Int      @default(0)
  premiumsOnHealthHospital Decimal  @db.Decimal(12, 2) @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, effectiveYear])
  @@map("tax_exemptions")
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  action    String
  entity    String
  entityId  String
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([companyId, entity])
  @@index([entityId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// GEOLOCATION TRACKING
// ─────────────────────────────────────────────

model LocationPing {
  id          String    @id @default(cuid())
  employeeId  String
  dtrRecordId String?
  lat         Float
  lng         Float
  accuracy    Float?
  recordedAt  DateTime  @default(now())

  employee    Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  dtrRecord   DTRRecord? @relation(fields: [dtrRecordId], references: [id], onDelete: SetNull)

  @@index([employeeId, recordedAt])
  @@map("location_pings")
}

// ─────────────────────────────────────────────
// 13TH MONTH PAY TRACKING
// ─────────────────────────────────────────────

model ThirteenthMonthLog {
  id               String    @id @default(cuid())
  companyId        String
  employeeId       String
  year             Int
  janBasic         Decimal   @default(0) @db.Decimal(12, 2)
  febBasic         Decimal   @default(0) @db.Decimal(12, 2)
  marBasic         Decimal   @default(0) @db.Decimal(12, 2)
  aprBasic         Decimal   @default(0) @db.Decimal(12, 2)
  mayBasic         Decimal   @default(0) @db.Decimal(12, 2)
  junBasic         Decimal   @default(0) @db.Decimal(12, 2)
  julBasic         Decimal   @default(0) @db.Decimal(12, 2)
  augBasic         Decimal   @default(0) @db.Decimal(12, 2)
  sepBasic         Decimal   @default(0) @db.Decimal(12, 2)
  octBasic         Decimal   @default(0) @db.Decimal(12, 2)
  novBasic         Decimal   @default(0) @db.Decimal(12, 2)
  decBasic         Decimal   @default(0) @db.Decimal(12, 2)
  totalBasicPaid   Decimal   @default(0) @db.Decimal(12, 2)
  thirteenthAmount Decimal   @default(0) @db.Decimal(12, 2)
  proRatedMonths   Decimal   @default(0) @db.Decimal(4, 2)
  isPaid           Boolean   @default(false)
  paidAt           DateTime?
  payrollRunId     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  company  Company  @relation(fields: [companyId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, year])
  @@index([companyId, year])
  @@map("thirteenth_month_logs")
}


// ─────────────────────────────────────────────
// ROLE-BASED PAGE PERMISSIONS (per company)
// ─────────────────────────────────────────────

model CompanyRolePermission {
  id          String   @id @default(cuid())
  companyId   String
  role        UserRole
  permissions Json     // string[] — list of Permission keys granted to this role
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, role])
  @@map("company_role_permissions")
}

// ─────────────────────────────────────────────
// BILLING & SUBSCRIPTIONS
// ─────────────────────────────────────────────

model Subscription {
  id                 String             @id @default(cuid())
  companyId          String             @unique
  plan               SubscriptionPlan   @default(TRIAL)
  status             SubscriptionStatus @default(TRIAL)
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  billingCycle       String?            // 'MONTHLY' | 'ANNUAL'
  pricePerSeat       Decimal            @db.Decimal(10, 2) @default(50)
  seatCount          Int                @default(0)
  cancelledAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  company  Company   @relation(fields: [companyId], references: [id])
  invoices Invoice[]

  @@map("subscriptions")
}

model Invoice {
  id             String        @id @default(cuid())
  companyId      String
  subscriptionId String
  invoiceNo      String        @unique
  status         InvoiceStatus @default(UNPAID)
  periodStart    DateTime
  periodEnd      DateTime
  seatCount      Int
  pricePerSeat   Decimal       @db.Decimal(10, 2)
  subtotal       Decimal       @db.Decimal(12, 2)
  discountPct    Decimal       @db.Decimal(5, 2)  @default(0)
  discountAmount Decimal       @db.Decimal(12, 2) @default(0)
  total          Decimal       @db.Decimal(12, 2)
  paymentMethodCode  String?
  paymentMethodLabel String?
  dueDate        DateTime
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  company      Company      @relation(fields: [companyId], references: [id])
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("invoices")
}

model PaymentMethod {
  id            String            @id @default(cuid())
  code          String            @unique
  label         String
  type          PaymentMethodType @default(OTHER)
  bankName      String?
  accountName   String?
  accountNumber String?
  instructions  String?
  qrImageUrl    String?           @db.Text
  sortOrder     Int               @default(0)
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@map("payment_methods")
}

model ApproverConfig {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  type      String   // 'PAYROLL' | 'LEAVE'
  level     Int      @default(1)  // 1 = 1st approver, 2 = 2nd, 3 = 3rd, etc.
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([companyId, type, level])
  @@map("approver_configs")
}
