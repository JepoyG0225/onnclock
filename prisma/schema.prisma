  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  company     Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee    Employee                 @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  template    OnboardingTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  application JobApplication?          @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  steps       OnboardingStepProgress[]

  @@index([companyId, status, createdAt])
  @@index([employeeId, status, createdAt])
  @@index([applicationId])
  @@map("onboarding_processes")
}

model OnboardingStepProgress {
  id             String               @id @default(cuid())
  processId      String
  templateStepId String?
  title          String
  stepType       OnboardingStepType   @default(TASK)
  isRequired     Boolean              @default(true)
