  status             InvoiceStatus @default(UNPAID)
  periodStart        DateTime
  periodEnd          DateTime
  seatCount          Int
  pricePerSeat       Decimal       @db.Decimal(10, 2)
  subtotal           Decimal       @db.Decimal(12, 2)
  discountPct        Decimal       @default(0) @db.Decimal(5, 2)
  discountAmount     Decimal       @default(0) @db.Decimal(12, 2)
  total              Decimal       @db.Decimal(12, 2)
  paymentMethodCode  String?
  paymentMethodLabel String?
  dueDate            DateTime
  paidAt             DateTime?
  notes              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  company      Company      @relation(fields: [companyId], references: [id])
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("invoices")
}

model PaymentMethod {
  id            String            @id @default(cuid())
  code          String            @unique
  label         String
  type          PaymentMethodType @default(OTHER)
  bankName      String?
  accountName   String?
  accountNumber String?
  instructions  String?
  qrImageUrl    String?           @db.Text
  sortOrder     Int               @default(0)
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@map("payment_methods")
}

model ApproverConfig {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  type      String // 'PAYROLL' | 'LEAVE'
  level     Int      @default(1) // 1 = 1st approver, 2 = 2nd, 3 = 3rd, etc.
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([companyId, type, level])
  @@map("approver_configs")
}

// ─────────────────────────────────────────────
// CHAT GROUPS
// ─────────────────────────────────────────────

model ChatGroup {
  id        String   @id @default(cuid())
  companyId String
  name      String
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members ChatGroupMember[]

  @@index([companyId])
  @@map("chat_groups")
}

model ChatGroupMember {
  id      String   @id @default(cuid())
  groupId String
  userId  String
  addedAt DateTime @default(now())

  group ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@map("chat_group_members")
}

// ─────────────────────────────────────────────
// BUDGET REQUISITIONS
// ─────────────────────────────────────────────

model BudgetRequisition {
  id          String                  @id @default(cuid())
  companyId   String
  employeeId  String
  title       String
  purpose     String                  @db.Text
  totalAmount Decimal                 @db.Decimal(14, 2)
  currency    String                  @default("PHP")
  status      BudgetRequisitionStatus @default(PENDING)
  neededBy    DateTime?               @db.Date
  reviewedBy  String?
  reviewNote  String?                 @db.Text
  reviewedAt  DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  company     Company                       @relation(fields: [companyId], references: [id])
  employee    Employee                      @relation(fields: [employeeId], references: [id])
  items       BudgetRequisitionItem[]
  attachments BudgetRequisitionAttachment[]

  @@index([companyId, status])
  @@index([employeeId, createdAt])
  @@map("budget_requisitions")
}

model BudgetRequisitionItem {
  id            String            @id @default(cuid())
  requisitionId String
  description   String
  quantity      Decimal           @db.Decimal(10, 2)
  unit          String?
  unitCost      Decimal           @db.Decimal(14, 2)
  totalCost     Decimal           @db.Decimal(14, 2)
  createdAt     DateTime          @default(now())

  requisition BudgetRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)

  @@index([requisitionId])
  @@map("budget_requisition_items")
}

model BudgetRequisitionAttachment {
  id            String            @id @default(cuid())
  requisitionId String
  fileName      String
  fileUrl       String
  fileSize      Int
  mimeType      String
  uploadedBy    String?
  createdAt     DateTime          @default(now())

  requisition BudgetRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)

  @@index([requisitionId])
  @@map("budget_req_attachments")
}

enum TimeEntryCorrectionStatus {
  PENDING
  APPROVED
  REJECTED
}

model TimeEntryCorrection {
  id           String                     @id @default(cuid())
  companyId    String
  employeeId   String
  dtrRecordId  String?                    // optional — new entries won't have an existing record
  date         DateTime                   @db.Date
  // Requested values (null = no change requested for that field)
  timeIn       String?                    // "HH:mm" local Manila time
  timeOut      String?
  breakIn      String?
  breakOut     String?
  reason       String
  status       TimeEntryCorrectionStatus  @default(PENDING)
  adminNotes   String?
  reviewedBy   String?
  reviewedAt   DateTime?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  company  Company  @relation(fields: [companyId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([companyId, status])
  @@index([employeeId, createdAt])
  @@map("time_entry_corrections")
}
