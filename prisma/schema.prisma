generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  HR_MANAGER
  PAYROLL_OFFICER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum EmploymentStatus {
  PROBATIONARY
  REGULAR
  CONTRACTUAL
  PROJECT_BASED
  PART_TIME
  RESIGNED
  TERMINATED
  RETIRED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACTUAL
}

enum PayFrequency {
  SEMI_MONTHLY
  MONTHLY
  WEEKLY
  DAILY
}

enum RateType {
  MONTHLY
  DAILY
  HOURLY
}

enum IncomeTypeMode {
  FIXED
  VARIABLE
}

enum PayrollRunStatus {
  DRAFT
  COMPUTED
  FOR_APPROVAL
  APPROVED
  LOCKED
  CANCELLED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum BudgetRequisitionStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LoanType {
  SSS_SALARY_LOAN
  SSS_CALAMITY_LOAN
  PAGIBIG_MULTI_PURPOSE
  PAGIBIG_CALAMITY
  COMPANY_LOAN
  OTHER
}

enum LoanStatus {
  ACTIVE
  FULLY_PAID
  CANCELLED
}

enum SubscriptionPlan {
  TRIAL
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  UNPAID
  PAID
  VOID
}

enum PaymentMethodType {
  GCASH
  BANK_TRANSFER
  E_WALLET
  OTHER
}

enum HolidayType {
  REGULAR
  SPECIAL_NON_WORKING
  SPECIAL_WORKING
}

enum WorkScheduleType {
  FIXED
  FLEXITIME
  SHIFTING
  COMPRESSED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum CivilStatus {
  SINGLE
  MARRIED
  WIDOWED
  LEGALLY_SEPARATED
}

enum RecruitmentVisibility {
  DRAFT
  PUBLISHED
  CLOSED
}

enum RecruitmentStage {
  APPLIED
  SCREENING
  INTERVIEW
  FINAL_INTERVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

enum RecruitmentEmailTemplateType {
  INTERVIEW
  REJECTION
  OFFER
}

enum OnboardingStepType {
  DOCUMENT
  VIDEO
  TASK
  ORIENTATION
  SYSTEM_ACCESS
  POLICY_ACKNOWLEDGEMENT
}

enum OnboardingProcessStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OnboardingStepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum PerformanceReviewStatus {
  DRAFT
  IN_REVIEW
  COMPLETED
  ACKNOWLEDGED
}

enum OffboardingReason {
  RESIGNATION
  TERMINATION
  RETIREMENT
  END_OF_CONTRACT
  REDUNDANCY
}

enum OffboardingStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OvertimeRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum DisciplinaryType {
  NOTICE_TO_EXPLAIN
  NOTICE_OF_DECISION
  WRITTEN_WARNING
  SUSPENSION
  DEMOTION
  TERMINATION
}

enum DisciplinaryStatus {
  OPEN
  RESPONDED
  CLOSED
}

// ─────────────────────────────────────────────
// AUTH USERS
// ─────────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String
  name                String?
  isActive            Boolean   @default(true)
  lastLoginAt         DateTime?
  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  companies       UserCompany[]
  approverConfigs ApproverConfig[]

  @@map("users")
}

// ─────────────────────────────────────────────
// MULTI-TENANCY: COMPANIES
// ─────────────────────────────────────────────

model Company {
  id                            String   @id @default(cuid())
  name                          String
  tradeName                     String?
  industry                      String?
  tin                           String?
  sssRegistrationNo             String?
  philhealthNo                  String?
  pagibigNo                     String?
  address                       String?
  city                          String?
  province                      String?
  zipCode                       String?
  phone                         String?
  email                         String?
  senderEmail                   String?
  senderName                    String?
  smtpHost                      String?
  smtpPort                      Int?
  smtpSecure                    Boolean  @default(true)
  smtpUser                      String?
  smtpPass                      String?
  smtpFromEmail                 String?
  smtpFromName                  String?
  website                       String?
  birNo                         String?
  portalUrl                     String?
  portalSubdomain               String?  @unique
  logoUrl                       String?  @db.Text
  geofenceEnabled               Boolean  @default(false)
  fingerprintRequired           Boolean  @default(true)
  selfieRequired                Boolean  @default(false)
  screenCaptureEnabled          Boolean  @default(false)
  screenCaptureFrequencyMinutes Int      @default(5)
  geofenceLat                   Float?
  geofenceLng                   Float?
  geofenceRadiusMeters          Int?
  defaultBreakMinutes           Int      @default(60)
  timezone                      String   @default("Asia/Manila")
  payrollCurrency               String   @default("PHP")
  thirteenthPayStartMonth       Int      @default(1)
  thirteenthPayStartDay         Int      @default(1)
  thirteenthPayEndMonth         Int      @default(12)
  thirteenthPayEndDay           Int      @default(31)
  careerBannerUrl               String?  @db.Text
  careerTagline                 String?
  careerDescription             String?  @db.Text
  careerSocialFacebook          String?
  careerSocialLinkedin          String?
  careerSocialTwitter           String?
  careerSocialInstagram         String?
  isActive                      Boolean  @default(true)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  users                 UserCompany[]
  departments           Department[]
  positions             Position[]
  payGrades             PayGrade[]
  employees             Employee[]
  workSchedules         WorkSchedule[]
  holidays              Holiday[]
  payrollRuns           PayrollRun[]
  attendanceScreenshots AttendanceScreenshot[]
  payrollCycleConfig    PayrollCycleConfig?
  leaveTypes            LeaveType[]
  loans                 EmployeeLoan[]
  contributionConfig    ContributionConfig?
  deMinimisConfig       DeMinimisConfig?
  thirteenthMonthLogs   ThirteenthMonthLog[]
  rolePermissions       CompanyRolePermission[]
  approverConfigs       ApproverConfig[]
  subscription          Subscription?
  invoices              Invoice[]
  shiftAssignments      EmployeeShiftAssignment[]
  incomeTypes           IncomeType[]
  jobPosts              JobPost[]
  jobApplications       JobApplication[]
  recruitmentEmailTemplates RecruitmentEmailTemplate[]
  onboardingTemplates   OnboardingTemplate[]
  onboardingProcesses   OnboardingProcess[]
  performanceReviews    PerformanceReview[]
  offboardingProcesses     OffboardingProcess[]
  offboardingTemplateItems OffboardingTemplateItem[]
  overtimeRequests         OvertimeRequest[]
  disciplinaryRecords      DisciplinaryRecord[]
  announcements            Announcement[]
  budgetRequisitions       BudgetRequisition[]
  timeEntryCorrections     TimeEntryCorrection[]

  @@map("companies")
}

model PayrollCycleConfig {
  id                     String       @id @default(cuid())
  companyId              String       @unique
  payFrequency           PayFrequency @default(SEMI_MONTHLY)
  firstCutoffStartDay    Int          @default(1)
  firstCutoffEndDay      Int          @default(15)
  secondCutoffStartDay   Int          @default(16)
  secondCutoffEndDay     Int          @default(31)
  defaultPayDelayDays    Int          @default(5)
  enableOvertime         Boolean      @default(true)
  enableNightDifferential Boolean     @default(true)
  nightDifferentialRate  Decimal      @default(0.10) @db.Decimal(5, 4)
  nightDifferentialStart String       @default("22:00")
  nightDifferentialEnd   String       @default("06:00")
  updatedAt              DateTime     @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("payroll_cycle_configs")
}

// ─────────────────────────────────────────────
// USER MANAGEMENT
// ─────────────────────────────────────────────

model UserCompany {
  id                  String   @id @default(cuid())
  userId              String
  companyId           String
  role                UserRole @default(EMPLOYEE)
  managedDepartmentId String?  // Only set for DEPARTMENT_HEAD role
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
  @@map("user_companies")
}

// ─────────────────────────────────────────────
// ORGANIZATIONAL STRUCTURE
// ─────────────────────────────────────────────

model Department {
  id        String   @id @default(cuid())
  companyId String
  name      String
  code      String?
  parentId  String?
  headId    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company      @relation(fields: [companyId], references: [id])
  parent    Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DeptHierarchy")
  employees Employee[]

  @@map("departments")
}

model Position {
  id         String   @id @default(cuid())
  companyId  String
  title      String
  code       String?
  payGradeId String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company   Company    @relation(fields: [companyId], references: [id])
  payGrade  PayGrade?  @relation(fields: [payGradeId], references: [id])
  employees Employee[]

  @@map("positions")
}

model PayGrade {
  id        String   @id @default(cuid())
  companyId String
  name      String
  minSalary Decimal  @db.Decimal(12, 2)
  maxSalary Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company    @relation(fields: [companyId], references: [id])
  positions Position[]

  @@map("pay_grades")
}

// ─────────────────────────────────────────────
// EMPLOYEE 201 FILE
// ─────────────────────────────────────────────

model Employee {
  id         String  @id @default(cuid())
  companyId  String
  employeeNo String
  userId     String?

  lastName    String
  firstName   String
  middleName  String?
  suffix      String?
  gender      Gender
  birthDate   DateTime    @db.Date
  birthPlace  String?
  civilStatus CivilStatus @default(SINGLE)
  nationality String      @default("Filipino")
  religion    String?

  personalEmail String?
  workEmail     String?
  mobileNo      String?
  phoneNo       String?

  presentAddress   String?
  permanentAddress String?

  sssNo        String?
  tinNo        String?
  philhealthNo String?
  pagibigNo    String?

  emergencyContactName     String?
  emergencyContactRelation String?
  emergencyContactPhone    String?

  departmentId       String?
  positionId         String?
  directManagerId    String?
  employmentStatus   EmploymentStatus @default(PROBATIONARY)
  employmentType     EmploymentType   @default(FULL_TIME)
  hireDate           DateTime         @db.Date
  regularizationDate DateTime?        @db.Date
  resignationDate    DateTime?        @db.Date
  terminationDate    DateTime?        @db.Date

  rateType       RateType     @default(MONTHLY)
  basicSalary    Decimal      @db.Decimal(12, 2)
  dailyRate      Decimal?     @db.Decimal(10, 2)
  hourlyRate     Decimal?     @db.Decimal(8, 2)
  payFrequency   PayFrequency @default(SEMI_MONTHLY)
  workScheduleId String?

  bankName      String?
  bankAccountNo String?

  isExemptFromTax     Boolean @default(false)
  isMinimumWageEarner Boolean @default(false)
  trackTime           Boolean @default(false)
  isActive            Boolean @default(true)
  fingerprintExempt   Boolean @default(false)
  geofenceExempt      Boolean @default(false)
  selfieExempt        Boolean @default(false)

  // Per-employee mandatory deduction toggles
  sssEnabled            Boolean @default(true)
  philhealthEnabled     Boolean @default(true)
  pagibigEnabled        Boolean @default(true)
  withholdingTaxEnabled Boolean @default(true)

  photoUrl             String?
  faceEmbedding        Json?
  faceEmbeddingModel   String?
  faceSetupAt          DateTime?
  faceConsentAt        DateTime?
  faceSetupPhoto       String?   @db.Text
  biometricCredential  Json?
  biometricChallenge   String?
  biometricChallengeAt DateTime?
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  company      Company       @relation(fields: [companyId], references: [id])
  department   Department?   @relation(fields: [departmentId], references: [id])
  position     Position?     @relation(fields: [positionId], references: [id])
  workSchedule WorkSchedule? @relation(fields: [workScheduleId], references: [id])
  manager      Employee?     @relation("ManagerSubordinate", fields: [directManagerId], references: [id])
  subordinates Employee[]    @relation("ManagerSubordinate")

  documents                    EmployeeDocument[]
  leaveBalances                LeaveBalance[]
  leaveRequests                LeaveRequest[]
  dtrRecords                   DTRRecord[]
  payslips                     Payslip[]
  loans                        EmployeeLoan[]
  taxExemptions                TaxExemption[]
  deMinimisItems               DeMinimisItem[]
  overtimeRecords              OvertimeRecord[]
  locationPings                LocationPing[]
  thirteenthMonthLogs          ThirteenthMonthLog[]
  incomeAssignments            EmployeeIncomeAssignment[]
  payrollIncomeEntries         PayrollRunIncomeEntry[]
  hiredApplications            JobApplication[]           @relation("HiredEmployeeApplications")
  onboardingProcesses          OnboardingProcess[]
  performanceReviewsAsReviewee PerformanceReview[]        @relation("RevieweePerformanceReviews")
  performanceReviewsAsReviewer PerformanceReview[]        @relation("ReviewerPerformanceReviews")
  attendanceScreenshots        AttendanceScreenshot[]
  offboardingProcesses         OffboardingProcess[]
  overtimeRequests             OvertimeRequest[]
  disciplinaryRecords          DisciplinaryRecord[]
  shiftAssignments             EmployeeShiftAssignment[]
  budgetRequisitions           BudgetRequisition[]
  timeEntryCorrections         TimeEntryCorrection[]

  @@unique([companyId, employeeNo])
  @@index([companyId])
  @@index([companyId, isActive])
  @@index([companyId, departmentId])
  @@index([companyId, employmentStatus])
  @@map("employees")
}

model EmployeeDocument {
  id           String    @id @default(cuid())
  employeeId   String
  documentType String
  fileName     String
  fileUrl      String
  uploadedAt   DateTime  @default(now())
  expiresAt    DateTime?
  notes        String?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_documents")
}

// ─────────────────────────────────────────────
// WORK SCHEDULE & HOLIDAYS
// ─────────────────────────────────────────────

model WorkSchedule {
  id                     String           @id @default(cuid())
  companyId              String
  name                   String
  scheduleType           WorkScheduleType @default(FIXED)
  requireSelfieOnClockIn Boolean          @default(false)
  workDays               Json
  timeIn                 String?
  timeOut                String?
  breakEnabled           Boolean          @default(true)
  breakMinutes           Int              @default(60)
  workHoursPerDay        Decimal          @default(8) @db.Decimal(4, 2)
  workDaysPerWeek        Int              @default(5)
  repeatCycle            String           @default("WEEKLY") // "WEEKLY" | "BIWEEKLY" | "MONTHLY"
  cycleWeeks             Json?            // [{label:string, workDays:number[]}] — only for BIWEEKLY/MONTHLY
  cycleStartDate         DateTime?        // Reference Monday to compute which cycle week is active
  isActive               Boolean          @default(true)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  company          Company                  @relation(fields: [companyId], references: [id])
  employees        Employee[]
  scheduleShifts   ScheduleShift[]
  shiftAssignments EmployeeShiftAssignment[]

  @@map("work_schedules")
}

// Per-employee per-day shift assignments (used by the weekly scheduling grid)
model EmployeeShiftAssignment {
  id         String    @id @default(cuid())
  companyId  String
  employeeId String
  date       DateTime  @db.Date
  scheduleId String?   // Optional link to a WorkSchedule template
  timeIn     String?   // "HH:MM" — overrides template if set
  timeOut    String?   // "HH:MM"
  isRestDay  Boolean   @default(false)
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  company  Company       @relation(fields: [companyId], references: [id])
  employee Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  schedule WorkSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  @@unique([employeeId, date])
  @@index([companyId, date])
  @@map("employee_shift_assignments")
}

model ScheduleShift {
  id             String @id @default(cuid())
  workScheduleId String
  shiftName      String
  dayOfWeek      Int?
  timeIn         String
  timeOut        String
  breakMinutes   Int    @default(60)

  workSchedule WorkSchedule @relation(fields: [workScheduleId], references: [id])

  @@map("schedule_shifts")
}

model Holiday {
  id          String      @id @default(cuid())
  companyId   String
  name        String
  date        DateTime    @db.Date
  type        HolidayType
  isRecurring Boolean     @default(true)
  description String?
  createdAt   DateTime    @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, date])
  @@map("holidays")
}

// ─────────────────────────────────────────────
// DAILY TIME RECORD (DTR)
// ─────────────────────────────────────────────

model DTRRecord {
  id               String       @id @default(cuid())
  employeeId       String
  date             DateTime     @db.Date
  timeIn           DateTime?
  timeOut          DateTime?
  breakIn          DateTime?
  breakOut         DateTime?
  regularHours     Decimal?     @db.Decimal(6, 2)
  overtimeHours    Decimal?     @db.Decimal(6, 2)
  nightDiffHours   Decimal?     @db.Decimal(6, 2)
  lateMinutes      Int?         @default(0)
  undertimeMinutes Int?         @default(0)
  isRestDay        Boolean      @default(false)
  isHoliday        Boolean      @default(false)
  holidayType      HolidayType?
  isAbsent         Boolean      @default(false)
  isLeave          Boolean      @default(false)
  isLeavePaid      Boolean      @default(false)
  leaveRequestId   String?
  source           String       @default("MANUAL")
  remarks          String?
  approvedBy       String?

  // GPS / Geolocation
  clockInLat       Float?
  clockInLng       Float?
  clockInAccuracy  Float?
  clockInAddress   String?
  clockInPhoto     String? @db.Text
  clockOutLat      Float?
  clockOutLng      Float?
  clockOutAccuracy Float?
  clockOutAddress  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee       Employee               @relation(fields: [employeeId], references: [id])
  locationPings  LocationPing[]
  screenCaptures AttendanceScreenshot[]

  @@unique([employeeId, date])
  @@index([employeeId, approvedBy])
  @@index([employeeId, date])
  @@index([employeeId, timeOut])
  @@map("dtr_records")
}

model AttendanceScreenshot {
  id           String   @id @default(cuid())
  companyId    String
  employeeId   String
  dtrRecordId  String
  imageDataUrl String   @db.Text
  capturedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  dtrRecord DTRRecord @relation(fields: [dtrRecordId], references: [id], onDelete: Cascade)

  @@index([companyId, capturedAt])
  @@index([employeeId, capturedAt])
  @@index([dtrRecordId, capturedAt])
  @@map("attendance_screenshots")
}

// ─────────────────────────────────────────────
// LEAVE MANAGEMENT
// ─────────────────────────────────────────────

model LeaveType {
  id                String   @id @default(cuid())
  companyId         String
  name              String
  code              String
  daysEntitled      Decimal  @db.Decimal(6, 2)
  isWithPay         Boolean  @default(true)
  isPaidOut         Boolean  @default(false)
  isMandatory       Boolean  @default(true)
  requiresDocuments Boolean  @default(false)
  genderRestriction String?
  accrualType       String   @default("ANNUAL")
  carryOver         Boolean  @default(false)
  maxCarryOver      Decimal? @db.Decimal(6, 2)
  isActive          Boolean  @default(true)
  description       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company       Company        @relation(fields: [companyId], references: [id])
  leaveBalances LeaveBalance[]
  leaveRequests LeaveRequest[]

  @@unique([companyId, code])
  @@map("leave_types")
}

model LeaveBalance {
  id          String   @id @default(cuid())
  employeeId  String
  leaveTypeId String
  year        Int
  entitled    Decimal  @db.Decimal(6, 2)
  used        Decimal  @default(0) @db.Decimal(6, 2)
  pending     Decimal  @default(0) @db.Decimal(6, 2)
  carriedOver Decimal  @default(0) @db.Decimal(6, 2)
  encashed    Decimal  @default(0) @db.Decimal(6, 2)
  updatedAt   DateTime @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
  @@map("leave_balances")
}

model LeaveRequest {
  id             String      @id @default(cuid())
  employeeId     String
  leaveTypeId    String
  startDate      DateTime    @db.Date
  endDate        DateTime    @db.Date
  totalDays      Decimal     @db.Decimal(6, 2)
  reason         String?
  status         LeaveStatus @default(PENDING)
  approvalLevel  Int         @default(0)
  approvalTrail  Json        @default("[]")
  supportingDocs Json        @default("[]")
  reviewedBy     String?
  reviewedAt     DateTime?
  reviewNotes    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([employeeId, status])
  @@index([employeeId, status, startDate, endDate])
  @@index([employeeId, createdAt])
  @@map("leave_requests")
}

// ─────────────────────────────────────────────
// CONTRIBUTION CONFIGURATION
// ─────────────────────────────────────────────

model ContributionConfig {
  id                   String   @id @default(cuid())
  companyId            String   @unique
  sssEmployeeRate      Decimal  @default(0.0450) @db.Decimal(6, 4)
  sssEmployerRate      Decimal  @default(0.0950) @db.Decimal(6, 4)
  sssEcRate            Decimal  @default(0.0010) @db.Decimal(6, 4)
  sssMinMsc            Decimal  @default(4000) @db.Decimal(12, 2)
  sssMaxMsc            Decimal  @default(30000) @db.Decimal(12, 2)
  philhealthRate       Decimal  @default(0.0500) @db.Decimal(6, 4)
  philhealthMinPremium Decimal  @default(500) @db.Decimal(12, 2)
  philhealthMaxSalary  Decimal  @default(100000) @db.Decimal(12, 2)
  pagibigEmployeeRate1 Decimal  @default(0.0100) @db.Decimal(6, 4)
  pagibigEmployeeRate2 Decimal  @default(0.0200) @db.Decimal(6, 4)
  pagibigThreshold     Decimal  @default(1500) @db.Decimal(12, 2)
  pagibigEmployerRate  Decimal  @default(0.0200) @db.Decimal(6, 4)
  pagibigMaxEmployee   Decimal  @default(100) @db.Decimal(12, 2)
  pagibigMaxEmployer   Decimal  @default(100) @db.Decimal(12, 2)
  updatedAt            DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@map("contribution_configs")
}

// ─────────────────────────────────────────────
// PAYROLL RUN
// ─────────────────────────────────────────────

model PayrollRun {
  id              String           @id @default(cuid())
  companyId       String
  periodLabel     String
  periodStart     DateTime         @db.Date
  periodEnd       DateTime         @db.Date
  payFrequency    PayFrequency
  payDate         DateTime         @db.Date
  status          PayrollRunStatus @default(DRAFT)
  approvalLevel   Int              @default(0)
  approvalTrail   Json             @default("[]")
  totalBasic      Decimal          @default(0) @db.Decimal(14, 2)
  totalGross      Decimal          @default(0) @db.Decimal(14, 2)
  totalDeductions Decimal          @default(0) @db.Decimal(14, 2)
  totalNetPay     Decimal          @default(0) @db.Decimal(14, 2)
  totalSssEr      Decimal          @default(0) @db.Decimal(14, 2)
  totalPhEr       Decimal          @default(0) @db.Decimal(14, 2)
  totalPagibigEr  Decimal          @default(0) @db.Decimal(14, 2)
  createdBy       String
  approvedBy      String?
  approvedAt      DateTime?
  lockedAt        DateTime?
  notes           String?
  createdAt       DateTime         @default(now())
